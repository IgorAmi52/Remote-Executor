# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT=http://localhost:4566

# SQS Queue URLs
COMMAND_QUEUE_URL=http://localhost:4566/000000000000/command-queue
STATUS_QUEUE_URL=http://localhost:4566/000000000000/status-queue

# Controller Configuration
# Path to the SQLite database file (parent directories will be created automatically)
DB_PATH=./db/controller.db

# Executor Polling Configuration
# Interval between polls when queue is empty (milliseconds)
POLL_INTERVAL_MS=1000
# SQS long polling wait time (seconds, max 20)
SQS_WAIT_TIME_S=20

# Executor SQS Visibility Timeout Configuration
# How long a message is invisible after being received (seconds)
VISIBILITY_TIMEOUT_S=300
# How often to extend visibility timeout (seconds, should be < VISIBILITY_TIMEOUT_S)
HEARTBEAT_INTERVAL_S=240

# Executor Docker Configuration
# Base image to use for task execution
DOCKER_IMAGE=bash:latest
