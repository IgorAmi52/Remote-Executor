# Terraform Variables Configuration
# Copy this file to terraform.tfvars and customize as needed
#
# =============================================================================
# AWS Configuration
# =============================================================================
# These values can be set here OR via environment variables (TF_VAR_ prefix).
# Environment variables take precedence if both are set.

aws_region     = "us-east-1"
aws_access_key = "test"      # For real AWS, use actual credentials or env vars
aws_secret_key = "test"      # For real AWS, use actual credentials or env vars

# =============================================================================
# LocalStack Configuration
# =============================================================================
# use_localstack: Controls provider behavior for local development
#   - true:  Skips AWS credential validation, uses custom endpoints
#   - false: Standard AWS behavior, requires valid credentials
#
# aws_endpoint: Custom endpoint URL for LocalStack
#   - Only effective when use_localstack = true
#   - For real AWS, this is ignored

use_localstack = true
aws_endpoint   = "http://localhost:4566"

# =============================================================================
# SQS Configuration
# =============================================================================
# queue_names: List of SQS queues to create
#   - command-queue: Receives execution requests from clients
#   - status-queue:  Publishes execution status updates

queue_names = [
  "command-queue",
  "status-queue"
]

# =============================================================================
# Resource Tags
# =============================================================================
# Common tags applied to all created resources for organization and billing

tags = {
  Project     = "remote-executor"
  Environment = "localstack"      # Change to "dev", "staging", "prod" as needed
}
